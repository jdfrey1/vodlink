# ─────────────────────────────────────────────────────────────────────────────
# VodLink configuration
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── VodLink UI ───────────────────────────────────────────────────────────────
# Port the VodLink web interface is available on
VODLINK_PORT=7842

# ── VOD source (read-only) ───────────────────────────────────────────────────
# Host path to the VOD2MLIB output directory (contains Movies/ and Series/).
# Mounted read-only into the container at /vod/src.
VOD_SRC=/volume1/docker/dispatcharr/VODS

# ── VOD destination (read-write) ─────────────────────────────────────────────
# Host path to the root directory Emby scans (contains Movies/ and Series/).
# Mounted read-write into the container at /vod/dest.
VOD_DEST=/volume1/SSD/VOD

# ── Data directory ───────────────────────────────────────────────────────────
# Where VodLink stores its SQLite database and backups.
DATA_DIR=/volume1/docker/vodlink/data

# ── User/group for file ownership ────────────────────────────────────────────
# UID/GID the container runs as. Files will be created with this ownership.
# Run: id <your-user>  to find your UID/GID.
PUID=1000
PGID=1000

# ── Dispatcharr URL (optional) ───────────────────────────────────────────────
# If your VOD2MLIB .strm files contain a Dispatcharr URL that is not reachable
# from inside the VodLink container (e.g. Dispatcharr moved to a macvlan network),
# set this to the correct base URL. VodLink will rewrite the host:port in every
# .strm URL before proxying. Leave blank if .strm URLs are already reachable.
# DISPATCHARR_URL=http://192.168.40.80:9191

# ── Timezone ─────────────────────────────────────────────────────────────────
# IANA timezone name for scheduled scans. Find yours at:
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York

# ── Plex integration (optional) ──────────────────────────────────────────────
# To enable a FUSE virtual filesystem so Plex can read your linked media:
#
#   1. Create the host directory:  mkdir -p /your/plex/path
#   2. Uncomment the three lines below and set PLEX_MOUNT_DIR.
#   3. Restart the container: docker compose up -d --force-recreate
#
# Plex library paths:
#   Movies  →  ${PLEX_MOUNT_DIR}/Movies
#   TV Shows → ${PLEX_MOUNT_DIR}/Series
#
# COMPOSE_FILE=docker-compose.yml:docker-compose.plex.yml
# PLEX_MOUNT_DIR=/volume1/SSD/plex
#
# One-time host setup (re-run after NAS reboot):
#   mkdir -p /volume1/SSD/plex
#   chown ${PUID}:${PGID} /volume1/SSD/plex
#   mount --bind /volume1/SSD/plex /volume1/SSD/plex
#   mount --make-shared /volume1/SSD/plex
