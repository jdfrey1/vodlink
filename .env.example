# ─────────────────────────────────────────────────────────────────────────────
# VodLink configuration
# Copy this file to .env and fill in the values for your environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── VodLink UI ───────────────────────────────────────────────────────────────
# Port the VodLink web interface is available on
VODLINK_PORT=7842

# ── Source directories (read-only) ───────────────────────────────────────────
# Paths to your IPTV provider's VOD content directories on the host.
# IMPORTANT: These must be the exact host paths — they are mounted at the same
# path inside the container so that symlinks created by VodLink resolve
# correctly when Emby follows them on the host.
MOVIES_SRC=/volume1/docker/dispatcharr/VODS/Movies
SERIES_SRC=/volume1/docker/dispatcharr/VODS/Series

# ── Destination directories (read-write) ─────────────────────────────────────
# Paths to the directories that Emby scans. VodLink creates symlinks here.
# Same path-mirroring requirement as above.
MOVIES_DEST=/volume1/SSD/VOD/Movies
SERIES_DEST=/volume1/SSD/VOD/Series

# ── Data directory ───────────────────────────────────────────────────────────
# Where VodLink stores its SQLite database and backups.
DATA_DIR=/volume1/docker/vodlink/data

# ── Dispatcharr proxy (optional) ─────────────────────────────────────────────
# Remove the dispatcharr-proxy service from docker-compose.yml if you don't
# use Dispatcharr or your streams are directly reachable from the host.
#
# IP address of your Dispatcharr container on its macvlan network.
DISPATCHARR_IP=192.168.40.80
# Port Dispatcharr listens on.
DISPATCHARR_PORT=9191
# Host port to publish the proxy on (must match the port in your .strm files).
PROXY_PORT=9191

# ── Build version (optional) ─────────────────────────────────────────────────
# Set when building locally. GitHub Actions sets this from the git tag.
# VODLINK_VERSION=0.1.0
